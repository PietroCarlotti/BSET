    \label{fig:dcct_scatter_cdf}

\noindent Alt text: Left panel: scatter plot with points colored by treatment arm (blue for treatment, vermillion for control), showing a strong positive association between surrogate and primary outcome with data points closely aligned along the diagonal; fitted LOESS curves for each arm closely follow the diagonal. Right panel: empirical CDF plot with four curves distinguished by color (blue or vermillion) and linetype (solid or dashed) for treatment versus control and primary outcome versus surrogate; the CDF curves for the surrogate and primary outcome are closely matched within each arm.
\end{figure}
