    \begin{subfigure}[b]{0.48\textwidth}
        \centering
        \includegraphics[width=\textwidth]{DCCT_X_theta_posterior_plot.pdf}
        \caption{With covariates (age and sex)}
    \end{subfigure}
    \caption{Left panel: posterior distribution of \(\theta\) applying the method with no covariates. Right panel: posterior distribution of \(\theta\) incorporating age and sex as covariates. Both panels use data from the high-risk subgroup of the DCCT.}
    \label{fig:dcct_post}

\noindent Alt text: Two side-by-side histogram plots of the posterior distribution of theta, the discrepancy parameter. In both panels the distribution is concentrated near zero and well below the validation threshold, supporting the conclusion that the surrogate is valid. Vertical lines indicate the credible interval upper bound and the validation threshold. The right panel, incorporating age and sex as covariates, shows a slightly more concentrated posterior closer to zero compared to the left panel.
\end{figure}
