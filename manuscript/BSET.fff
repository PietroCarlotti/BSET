\begin{figure}[ht]
    \centering
    \begin{subfigure}[b]{0.48\textwidth}
        \centering
        \includegraphics[width=\textwidth]{distance_plot_X_binary.pdf}
        \caption{Binary covariate}
        \label{fig:distance_plot_X_binary}
    \end{subfigure}
    \hfill
    \begin{subfigure}[b]{0.48\textwidth}
        \centering
        \includegraphics[width=\textwidth]{distance_plot_X_Gaussian.pdf}
        \caption{Gaussian covariate}
        \label{fig:distance_plot_X_Gaussian}
    \end{subfigure}
    \caption{Left panel: plot of \(|\theta - \delta|\) as a function of \(d_Y\) and \(d_S\) in the binary covariate setting, with \(\Delta = 5\). Right panel: plot of \(|\theta - \delta|\) as a function of \(\beta_{Y_0}\) and \(\beta_{S_0}\) in the Gaussian covariate setting, with \(\Delta = 2\), \(m = 2\), and \(v = 2\).}
    \label{fig:discrepancy_heatmaps}

\noindent Alt text: Two side-by-side heatmaps showing the absolute discrepancy between the causal estimand theta and the rank-based estimand delta as a function of two parameters, using a perceptually uniform color scale from dark purple (low discrepancy) to yellow (high discrepancy). The left panel varies d-Y and d-S in the binary covariate setting; the right panel varies the regression slopes beta-Y0 and beta-S0 in the Gaussian covariate setting. Both panels show that the discrepancy can be large in regions where the parameters for the primary outcome and surrogate differ substantially.
\end{figure}
