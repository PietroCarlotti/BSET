\begin{figure}[ht]
    \centering
    \begin{subfigure}[b]{0.48\textwidth}
        \centering
        \includegraphics[width=\textwidth]{DCCT_Y.pdf}
        \caption{Primary outcome}
    \end{subfigure}
    \hfill
    \begin{subfigure}[b]{0.48\textwidth}
        \centering
        \includegraphics[width=\textwidth]{DCCT_S.pdf}
        \caption{Surrogate}
    \end{subfigure}
    \caption{Left panel: histograms of the primary outcome (change in HbA1c from baseline to 4.5 years) by treatment arm. Right panel: histograms of the surrogate (change in HbA1c from baseline to 1.5 years) by treatment arm. Both panels focus on the high-risk subgroup of the DCCT dataset.}
    \label{fig:dcct}

\noindent Alt text: Two side-by-side overlapping histograms comparing treatment and control groups. In both panels, the treatment group distribution (blue) is shifted to the right relative to the control group (vermillion), indicating a beneficial treatment effect. The left panel shows change in HbA1c at 4.5 years; the right panel shows change in HbA1c at 1.5 years. The similar shift patterns in both panels provide visual evidence that the surrogate captures the treatment effect on the primary outcome.
\end{figure}
